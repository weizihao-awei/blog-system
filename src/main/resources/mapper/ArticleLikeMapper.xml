<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ykw.blog_system.mapper.ArticleLikeMapper">
    
    <resultMap id="BaseResultMap" type="com.ykw.blog_system.entity.ArticleLike">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="article_id" property="articleId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, user_id, article_id, create_time
    </sql>
    
    <select id="selectByUserAndArticle" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM article_like
        WHERE user_id = #{userId} AND article_id = #{articleId}
    </select>
    
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM article_like WHERE user_id = #{userId}
    </select>
    
    <select id="selectByArticleId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM article_like WHERE article_id = #{articleId}
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO article_like (user_id, article_id) VALUES (#{userId}, #{articleId})
    </insert>
    
    <delete id="deleteById">
        DELETE FROM article_like WHERE id = #{id}
    </delete>
    
    <delete id="deleteByUserAndArticle">
        DELETE FROM article_like WHERE user_id = #{userId} AND article_id = #{articleId}
    </delete>
    
    <select id="countByArticleId" resultType="java.lang.Long">
        SELECT COUNT(*) FROM article_like WHERE article_id = #{articleId}
    </select>
</mapper>
