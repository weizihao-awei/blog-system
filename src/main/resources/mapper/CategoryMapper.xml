<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ykw.blog_system.mapper.CategoryMapper">
    
    <resultMap id="BaseResultMap" type="com.ykw.blog_system.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, name, description, sort_order, status, create_time, update_time
    </sql>
    
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM category WHERE id = #{id}
    </select>
    
    <select id="selectByName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM category WHERE name = #{name}
    </select>
    
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM category
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY sort_order ASC, create_time DESC
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, description, sort_order, status)
        VALUES (#{name}, #{description}, #{sortOrder}, #{status})
    </insert>
    
    <update id="update">
        UPDATE category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status}</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>
    
    <select id="countCategories" resultType="java.lang.Long">
        SELECT COUNT(*) FROM category WHERE status = 1
    </select>
</mapper>
