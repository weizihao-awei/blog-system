<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ykw.blog_system.mapper.ArticleMapper">
    
    <resultMap id="BaseResultMap" type="com.ykw.blog_system.entity.Article">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="cover_image" property="coverImage"/>
        <result column="author_id" property="authorId"/>
        <result column="category_id" property="categoryId"/>
        <result column="article_content_id" property="articleContentId"/>
        <result column="view_count" property="viewCount"/>
        <result column="like_count" property="likeCount"/>
        <result column="comment_count" property="commentCount"/>
        <result column="status" property="status"/>
        <result column="is_top" property="isTop"/>
        <result column="is_recommend" property="isRecommend"/>
        <result column="publish_time" property="publishTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <resultMap id="ArticleWithAuthorResultMap" type="com.ykw.blog_system.entity.Article" extends="BaseResultMap">
        <result column="author_name" property="authorName"/>
        <result column="author_avatar" property="authorAvatar"/>
        <result column="category_name" property="categoryName"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        a.id, a.title, a.summary, a.cover_image,
        a.author_id, a.category_id, a.article_content_id, a.view_count, a.like_count, a.comment_count,
        a.status, a.is_top, a.is_recommend, a.publish_time, a.create_time, a.update_time
    </sql>

    <select id="countArticles" resultType="java.lang.Long">
        SELECT COUNT(*) FROM article
        <where>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>
    
    <select id="sumViewCount" resultType="java.lang.Long">
        SELECT COALESCE(SUM(view_count), 0) FROM article WHERE status = 1
    </select>
    
    <!-- 分页查询文章（支持多条件查询，包括标签） -->
    <select id="selectArticlesByCondition" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM article a
        <if test="queryDTO.tagIds != null and !queryDTO.tagIds.isEmpty()">
            INNER JOIN article_tag at ON a.id = at.article_id
        </if>
        <where>
            a.status = 1
            <if test="queryDTO.categoryId != null">
                AND a.category_id = #{queryDTO.categoryId}
            </if>
            <if test="queryDTO.tagIds != null and !queryDTO.tagIds.isEmpty()">
                AND at.tag_id IN
                <foreach collection="queryDTO.tagIds" item="tagId" open="(" separator="," close=")">
                    #{tagId}
                </foreach>
            </if>
            <if test="queryDTO.keyword != null and queryDTO.keyword != ''">
                AND (a.title LIKE CONCAT('%', #{queryDTO.keyword}, '%') OR a.summary LIKE CONCAT('%', #{queryDTO.keyword}, '%'))
            </if>
        </where>
        <choose>
            <when test="queryDTO.orderBy.name == 'CREATE_TIME_ASC'">
                ORDER BY a.create_time ASC
            </when>
            <when test="queryDTO.orderBy.name == 'CREATE_TIME_DESC'">
                ORDER BY a.create_time DESC
            </when>
            <when test="queryDTO.orderBy.name == 'UPDATE_TIME_ASC'">
                ORDER BY a.update_time ASC
            </when>
            <when test="queryDTO.orderBy.name == 'UPDATE_TIME_DESC'">
                ORDER BY a.update_time DESC
            </when>
            <otherwise>
                ORDER BY a.create_time DESC
            </otherwise>
        </choose>
    </select>
</mapper>
